# Copy this file to .env and fill in your own values.
# .env is already ignored by git.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_APP_PASSWORD=YOUR_16_CHAR_APP_PASSWORD
SMTP_FROM=your_email@gmail.com
GOOGLE_SHEET_NAME=主售票系統  2026 春映洄瀾，拾光
SHEET_SCHEMA_VERSION=2026.04.17.v1

# Security notes:
# 1) Never commit .env to git.
# 2) Rotate SMTP App Password before production deployment.
# 3) Keep credentials.json local only.

# Optional
# PAYMENT_DEADLINE_TEXT=請於 3 日內完成匯款
# PUSH_ENABLED=false
# PUSH_PROVIDER=telegram
# PUSH_TARGET_EMAIL=
# PUSH_TELEGRAM_BOT_TOKEN=
# PUSH_TELEGRAM_CHAT_ID=
# PUSH_LINE_NOTIFY_TOKEN=
